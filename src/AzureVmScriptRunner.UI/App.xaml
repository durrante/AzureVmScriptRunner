<Application x:Class="AzureVmScriptRunner.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AzureVmScriptRunner.UI.ViewModels"
             xmlns:views="clr-namespace:AzureVmScriptRunner.UI.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ViewModel-first navigation: each view model renders as its view -->
            <DataTemplate DataType="{x:Type vm:VmsViewModel}">
                <views:VmsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:RunViewModel}">
                <views:RunView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DeployViewModel}">
                <views:DeployView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:TasksViewModel}">
                <views:TasksView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:PrepViewModel}">
                <views:PrepView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
                <views:HistoryView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ScheduleViewModel}">
                <views:ScheduleView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:PlaceholderViewModel}">
                <views:PlaceholderView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
