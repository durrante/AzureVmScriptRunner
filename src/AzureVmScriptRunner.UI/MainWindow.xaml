<Window x:Class="AzureVmScriptRunner.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AzureVmScriptRunner.UI.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="{Binding WindowTitle, Mode=OneTime}"
        Icon="Assets/avsr.ico"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="64"/>   <!-- Gradient header -->
      <RowDefinition Height="Auto"/> <!-- Connection strip -->
      <RowDefinition Height="*"/>    <!-- Nav + content -->
      <RowDefinition Height="Auto"/> <!-- Footer -->
    </Grid.RowDefinitions>

    <!-- ═══ HEADER (suite signature gradient) ═══ -->
    <Border Grid.Row="0" Background="{StaticResource Brush.HeaderGradient}">
      <Grid Margin="20,0">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <!-- App mark: gradient console prompt (says what the tool does) -->
          <Border Width="38" Height="38" CornerRadius="10" Background="White" Margin="0,0,12,0">
            <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                       HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock.Foreground>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Color="{StaticResource Color.GradientStart}" Offset="0"/>
                  <GradientStop Color="{StaticResource Color.GradientEnd}" Offset="1"/>
                </LinearGradientBrush>
              </TextBlock.Foreground>
            </TextBlock>
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Azure VM Script Runner" Style="{StaticResource Text.HeaderTitle}"/>
            <TextBlock Style="{StaticResource Text.HeaderSubtitle}" Margin="0,1,0,0">
              <Run Text="Execute scripts, commands &amp; PSADT deployments on Azure Windows VMs — no RDP required  •  "/>
              <Hyperlink NavigateUri="https://modernworkspacehub.com"
                         RequestNavigate="Blog_RequestNavigate"
                         Foreground="{StaticResource Brush.Subtitle}" TextDecorations="None">modernworkspacehub.com</Hyperlink>
            </TextBlock>
          </StackPanel>
        </StackPanel>
        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12"
                   Foreground="White" Text="{Binding UserDisplay}"/>
      </Grid>
    </Border>

    <!-- ═══ CONNECTION STRIP ═══ -->
    <Border Grid.Row="1" Background="#F0F0F0" BorderBrush="{StaticResource Brush.BorderLight}"
            BorderThickness="0,0,0,1" Padding="20,7">
      <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Ellipse Width="10" Height="10" Margin="0,0,8,0">
            <Ellipse.Style>
              <Style TargetType="Ellipse">
                <Setter Property="Fill" Value="{StaticResource Brush.StatusRed}"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsConnected}" Value="True">
                    <Setter Property="Fill" Value="{StaticResource Brush.StatusGreen}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Ellipse.Style>
          </Ellipse>
          <TextBlock FontSize="12" VerticalAlignment="Center">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Text" Value="Not connected"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsConnected}" Value="True">
                    <Setter Property="Text" Value="{Binding UserDisplay, StringFormat='Connected as {0}'}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </StackPanel>
        <Button Content="Connect to Azure" HorizontalAlignment="Right"
                Style="{StaticResource Button.Primary}"
                Command="{Binding ConnectCommand}"
                Visibility="{Binding IsConnected, Converter={StaticResource InverseBoolToVis}}"/>
      </Grid>
    </Border>

    <!-- ═══ NAV RAIL + CONTENT ═══ -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="78"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <ListBox Grid.Column="0" Style="{StaticResource Nav.List}"
               ItemsSource="{Binding NavItems}"
               SelectedItem="{Binding SelectedNavItem}"/>

      <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="0"/>
    </Grid>

    <!-- ═══ FOOTER ═══ -->
    <Border Grid.Row="3" Background="{StaticResource Brush.Footer}"
            BorderBrush="{StaticResource Brush.BorderLight}" BorderThickness="0,1,0,0" Padding="16,5">
      <Grid>
        <TextBlock Text="{Binding StatusText}" Style="{StaticResource Text.Footer}"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
          <TextBlock FontSize="10" Foreground="{StaticResource Brush.TextFaint}"
                     VerticalAlignment="Center" Text="{Binding FooterBrand, Mode=OneTime}"/>
          <!-- modernworkspacehub.com mark -->
          <Image Source="Assets/logo.png" Width="14" Height="14" Margin="6,0,0,0"
                 VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"
                 ToolTip="modernworkspacehub.com"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
