<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:AzureVmScriptRunner.UI.Converters">

  <BooleanToVisibilityConverter x:Key="BoolToVis"/>
  <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>

  <!-- ═══ Suite palette (derived from Win32Forge) ═══ -->
  <Color x:Key="Color.GradientStart">#0693E3</Color>
  <Color x:Key="Color.GradientEnd">#9B51E0</Color>

  <SolidColorBrush x:Key="Brush.Brand"            Color="#4A2B8F"/>
  <SolidColorBrush x:Key="Brush.BrandDark"        Color="#2D1B69"/>
  <SolidColorBrush x:Key="Brush.BrandMid"         Color="#3A2673"/>
  <SolidColorBrush x:Key="Brush.Accent"           Color="#5BA3E8"/>
  <SolidColorBrush x:Key="Brush.Subtitle"         Color="#D4C5F9"/>
  <SolidColorBrush x:Key="Brush.PanelLavender"    Color="#F0EBF9"/>
  <SolidColorBrush x:Key="Brush.PanelLavenderAlt" Color="#EDE7F6"/>
  <SolidColorBrush x:Key="Brush.Selection"        Color="#E8DEFF"/>
  <SolidColorBrush x:Key="Brush.StatusGreen"      Color="#2E7D32"/>
  <SolidColorBrush x:Key="Brush.StatusRed"        Color="#D32F2F"/>
  <SolidColorBrush x:Key="Brush.StatusAmber"      Color="#F59E0B"/>
  <SolidColorBrush x:Key="Brush.Border"           Color="#CCCCCC"/>
  <SolidColorBrush x:Key="Brush.BorderLight"      Color="#DDDDDD"/>
  <SolidColorBrush x:Key="Brush.Footer"           Color="#F5F5F5"/>
  <SolidColorBrush x:Key="Brush.RowAlt"           Color="#FAFAFA"/>
  <SolidColorBrush x:Key="Brush.TextMuted"        Color="#666666"/>
  <SolidColorBrush x:Key="Brush.TextFaint"        Color="#AAAAAA"/>
  <SolidColorBrush x:Key="Brush.InputReadOnly"    Color="#F9F9F9"/>

  <LinearGradientBrush x:Key="Brush.HeaderGradient" StartPoint="0,0.5" EndPoint="1,0.5">
    <GradientStop Color="{StaticResource Color.GradientStart}" Offset="0"/>
    <GradientStop Color="{StaticResource Color.GradientEnd}" Offset="1"/>
  </LinearGradientBrush>

  <!-- ═══ Typography ═══ -->
  <Style x:Key="Text.HeaderTitle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="20"/>
    <Setter Property="FontWeight" Value="Light"/>
    <Setter Property="Foreground" Value="White"/>
  </Style>

  <Style x:Key="Text.HeaderSubtitle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Foreground" Value="{StaticResource Brush.Subtitle}"/>
  </Style>

  <Style x:Key="Text.SectionHeader" TargetType="TextBlock">
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource Brush.Brand}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Margin" Value="0,10,0,4"/>
  </Style>

  <Style x:Key="Text.Footer" TargetType="TextBlock">
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>

  <!-- ═══ Buttons: flat, radius 3-4, opacity feedback (suite convention) ═══ -->
  <ControlTemplate x:Key="Template.FlatButton" TargetType="Button">
    <Border x:Name="bd" Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="3" Padding="{TemplateBinding Padding}">
      <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Border>
    <ControlTemplate.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter TargetName="bd" Property="Opacity" Value="0.82"/>
      </Trigger>
      <Trigger Property="IsPressed" Value="True">
        <Setter TargetName="bd" Property="Opacity" Value="0.65"/>
      </Trigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
      </Trigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>

  <Style x:Key="Button.Tool" TargetType="Button">
    <Setter Property="Padding" Value="10,4"/>
    <Setter Property="Margin" Value="0,0,5,0"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
    <Setter Property="Background" Value="White"/>
    <Setter Property="Template" Value="{StaticResource Template.FlatButton}"/>
  </Style>

  <Style x:Key="Button.Primary" TargetType="Button" BasedOn="{StaticResource Button.Tool}">
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="Background" Value="{StaticResource Brush.Brand}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="12,5"/>
  </Style>

  <Style x:Key="Button.Accent" TargetType="Button" BasedOn="{StaticResource Button.Primary}">
    <Setter Property="Background" Value="{StaticResource Brush.Accent}"/>
  </Style>

  <!-- Hero action: gradient fill (suite convention for the "main" button) -->
  <Style x:Key="Button.Hero" TargetType="Button" BasedOn="{StaticResource Button.Primary}">
    <Setter Property="Background" Value="{StaticResource Brush.HeaderGradient}"/>
    <Setter Property="Padding" Value="16,6"/>
  </Style>

  <Style x:Key="Button.HeaderChip" TargetType="Button" BasedOn="{StaticResource Button.Primary}">
    <Setter Property="Background" Value="{StaticResource Brush.BrandDark}"/>
    <Setter Property="Padding" Value="10,4"/>
  </Style>

  <!-- ═══ Nav rail ═══ -->
  <Style x:Key="Nav.List" TargetType="ListBox">
    <Setter Property="Background" Value="{StaticResource Brush.BrandDark}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    <Setter Property="ItemContainerStyle">
      <Setter.Value>
        <Style TargetType="ListBoxItem">
          <Setter Property="Cursor" Value="Hand"/>
          <Setter Property="Foreground" Value="#C9BFE8"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ListBoxItem">
                <Border x:Name="bd" Background="Transparent" Padding="14,12">
                  <StackPanel>
                    <TextBlock Text="{Binding Glyph}" FontFamily="Segoe MDL2 Assets" FontSize="20"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Title}" FontSize="11" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="#3A2673"/>
                  </Trigger>
                  <Trigger Property="IsSelected" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="#4A2B8F"/>
                    <Setter Property="Foreground" Value="White"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══ Inputs ═══ -->
  <Style TargetType="TextBox">
    <Setter Property="Padding" Value="4,3"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
  </Style>

  <Style TargetType="ComboBox">
    <Setter Property="Padding" Value="4,3"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>

  <Style x:Key="Input.Log" TargetType="TextBox">
    <Setter Property="IsReadOnly" Value="True"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
    <Setter Property="AcceptsReturn" Value="True"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="8"/>
    <Setter Property="FontFamily" Value="Consolas"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
  </Style>

  <Style x:Key="Input.Script" TargetType="TextBox">
    <Setter Property="AcceptsReturn" Value="True"/>
    <Setter Property="AcceptsTab" Value="True"/>
    <Setter Property="FontFamily" Value="Consolas"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Padding" Value="8"/>
    <Setter Property="TextWrapping" Value="NoWrap"/>
    <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
    <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
  </Style>

  <!-- ═══ DataGrid (suite convention: lavender headers, 28px rows) ═══ -->
  <Style TargetType="DataGrid">
    <Setter Property="AutoGenerateColumns" Value="False"/>
    <Setter Property="CanUserAddRows" Value="False"/>
    <Setter Property="CanUserDeleteRows" Value="False"/>
    <Setter Property="GridLinesVisibility" Value="Horizontal"/>
    <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Brush.BorderLight}"/>
    <Setter Property="HeadersVisibility" Value="Column"/>
    <Setter Property="AlternatingRowBackground" Value="{StaticResource Brush.RowAlt}"/>
    <Setter Property="RowBackground" Value="White"/>
    <Setter Property="Background" Value="White"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="ColumnHeaderHeight" Value="30"/>
    <Setter Property="RowHeight" Value="28"/>
    <Setter Property="RowHeaderWidth" Value="0"/>
    <Setter Property="SelectionMode" Value="Extended"/>
    <Setter Property="SelectionUnit" Value="FullRow"/>
    <Setter Property="EnableRowVirtualization" Value="True"/>
    <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
  </Style>

  <Style TargetType="DataGridColumnHeader">
    <Setter Property="Background" Value="{StaticResource Brush.PanelLavender}"/>
    <Setter Property="Foreground" Value="{StaticResource Brush.Brand}"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Padding" Value="8,0"/>
    <Setter Property="Height" Value="30"/>
    <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderLight}"/>
    <Setter Property="BorderThickness" Value="0,0,1,1"/>
  </Style>

  <Style TargetType="DataGridCell">
    <Setter Property="Padding" Value="6,0"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="DataGridCell">
          <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
            <ContentPresenter VerticalAlignment="Center"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="{StaticResource Brush.Selection}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.BrandDark}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- ═══ Panels ═══ -->
  <Style x:Key="Panel.Banner" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource Brush.PanelLavenderAlt}"/>
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Brand}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="3"/>
    <Setter Property="Padding" Value="10,7"/>
  </Style>

  <Style x:Key="Panel.Toolbar" TargetType="Border">
    <Setter Property="Background" Value="#F8F8F8"/>
    <Setter Property="BorderBrush" Value="#E0E0E0"/>
    <Setter Property="BorderThickness" Value="0,0,0,1"/>
    <Setter Property="Padding" Value="10,7"/>
  </Style>

</ResourceDictionary>
