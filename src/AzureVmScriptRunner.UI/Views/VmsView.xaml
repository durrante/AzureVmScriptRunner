<UserControl x:Class="AzureVmScriptRunner.UI.Views.VmsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AzureVmScriptRunner.UI.ViewModels"
             xmlns:views="clr-namespace:AzureVmScriptRunner.UI.Views"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:VmsViewModel}">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/> <!-- Toolbar -->
      <RowDefinition Height="*"/>    <!-- Grid -->
      <RowDefinition Height="Auto"/> <!-- Summary -->
    </Grid.RowDefinitions>

    <!-- Toolbar -->
    <Border Grid.Row="0" Style="{StaticResource Panel.Toolbar}">
      <WrapPanel VerticalAlignment="Center">
        <Button Content="Refresh" Style="{StaticResource Button.Primary}"
                Command="{Binding RefreshCommand}" Margin="0,0,10,0"/>

        <TextBlock Text="Search:" VerticalAlignment="Center" FontSize="11"
                   Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,4,0"/>
        <TextBox Width="200" VerticalAlignment="Center"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="Filter by VM name, resource group, subscription or tag"/>

        <views:FilterDropdown DataContext="{Binding SubscriptionFilter}" Margin="12,0,0,0"/>
        <views:FilterDropdown DataContext="{Binding ResourceGroupFilter}" Margin="12,0,0,0"/>
        <views:FilterDropdown DataContext="{Binding RegionFilter}" Margin="12,0,0,0"/>
        <views:FilterDropdown DataContext="{Binding PowerFilter}" Margin="12,0,0,0"/>

        <Separator Width="1" Background="{StaticResource Brush.BorderLight}" Margin="10,2"/>

        <Button Content="Select Visible" Style="{StaticResource Button.Tool}"
                Command="{Binding SelectVisibleCommand}"/>
        <Button Content="Clear Selection" Style="{StaticResource Button.Tool}"
                Command="{Binding ClearSelectionCommand}"/>

        <TextBlock Text="{Binding SelectionText}" VerticalAlignment="Center" FontSize="12"
                   FontWeight="SemiBold" Foreground="{StaticResource Brush.Brand}" Margin="8,0,0,0"/>
      </WrapPanel>
    </Border>

    <!-- VM grid -->
    <DataGrid Grid.Row="1" ItemsSource="{Binding VmsView}" IsReadOnly="False"
              SelectionMode="Extended">
      <DataGrid.Columns>
        <DataGridTemplateColumn Width="36" CanUserResize="False">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>

        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="170" IsReadOnly="True"/>
        <DataGridTextColumn Header="Subscription" Binding="{Binding Subscription}" Width="150" IsReadOnly="True"/>
        <DataGridTextColumn Header="Resource Group" Binding="{Binding ResourceGroup}" Width="160" IsReadOnly="True"/>
        <DataGridTextColumn Header="Region" Binding="{Binding Region}" Width="110" IsReadOnly="True"/>

        <DataGridTemplateColumn Header="Power" Width="130" SortMemberPath="PowerText" IsReadOnly="True">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="9" Height="9" Margin="0,0,6,0">
                  <Ellipse.Style>
                    <Style TargetType="Ellipse">
                      <Setter Property="Fill" Value="{StaticResource Brush.StatusAmber}"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                          <Setter Property="Fill" Value="{StaticResource Brush.StatusGreen}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding PowerText}" Value="Deallocated">
                          <Setter Property="Fill" Value="{StaticResource Brush.StatusRed}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding PowerText}" Value="Stopped">
                          <Setter Property="Fill" Value="{StaticResource Brush.StatusRed}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding PowerText}" VerticalAlignment="Center"/>
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>

        <DataGridTextColumn Header="Identity" Binding="{Binding IdentityText}" Width="70" IsReadOnly="True"/>
        <DataGridTextColumn Header="Tags" Binding="{Binding TagsText}" Width="*" IsReadOnly="True"/>
      </DataGrid.Columns>
    </DataGrid>

    <!-- Summary strip -->
    <Border Grid.Row="2" Background="{StaticResource Brush.Footer}"
            BorderBrush="{StaticResource Brush.BorderLight}" BorderThickness="0,1,0,0" Padding="12,4">
      <TextBlock Text="{Binding SummaryText}" Style="{StaticResource Text.Footer}"/>
    </Border>
  </Grid>
</UserControl>
