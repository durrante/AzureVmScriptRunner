<UserControl x:Class="AzureVmScriptRunner.UI.Views.DeployView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AzureVmScriptRunner.UI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:DeployViewModel}">

  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- Target safety panel -->
      <RowDefinition Height="Auto"/>  <!-- Deployment form -->
      <RowDefinition Height="Auto"/>  <!-- Actions -->
      <RowDefinition Height="*"/>     <!-- Results + log -->
    </Grid.RowDefinitions>

    <!-- Target safety panel -->
    <Border Grid.Row="0" Margin="0,0,0,8">
      <Border.Style>
        <Style TargetType="Border" BasedOn="{StaticResource Panel.Banner}">
          <Style.Triggers>
            <DataTrigger Binding="{Binding HasSelection}" Value="False">
              <Setter Property="Background" Value="#FFF8E1"/>
              <Setter Property="BorderBrush" Value="{StaticResource Brush.StatusAmber}"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <StackPanel>
        <TextBlock Text="{Binding TargetsText}" FontWeight="SemiBold"
                   Foreground="{StaticResource Brush.Brand}" FontSize="12"/>
        <ItemsControl ItemsSource="{Binding SelectedVmNames}" Margin="0,4,0,0">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Background="White" BorderBrush="{StaticResource Brush.Brand}"
                      BorderThickness="1" CornerRadius="9" Padding="8,2" Margin="0,2,6,2">
                <TextBlock Text="{Binding}" FontSize="11" Foreground="{StaticResource Brush.BrandDark}"/>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>

    <!-- Deployment form -->
    <StackPanel Grid.Row="1">
      <TextBlock Text="PSADT Package" Style="{StaticResource Text.SectionHeader}" Margin="0,0,0,4"/>

      <Grid Margin="0,3">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="120"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Label Content="Package URL *"/>
        <TextBox Grid.Column="1" Text="{Binding PackageUrl, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="Blob URL of the zipped PSADT package — no SAS token needed. Access uses the VM's managed identity, falling back to a 1-hour SAS issued under your identity."/>
      </Grid>
      <TextBlock FontSize="11" Foreground="{StaticResource Brush.TextMuted}" TextWrapping="Wrap" Margin="120,0,0,2"
                 Text="Full https:// URL to a .zip containing a complete PSADT package (toolkit + Files payload), e.g. https://account.blob.core.windows.net/container/App_1.0_PSADT.zip — no SAS token; access is handled automatically. Works with PSADT v3 and v4 (entry point auto-detected)."/>

      <Grid Margin="0,3">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="120"/>
          <ColumnDefinition Width="140"/>
          <ColumnDefinition Width="110"/>
          <ColumnDefinition Width="140"/>
          <ColumnDefinition Width="120"/>
          <ColumnDefinition Width="60"/>
        </Grid.ColumnDefinitions>
        <Label Content="Deployment Type"/>
        <ComboBox Grid.Column="1" ItemsSource="{Binding DeploymentTypes}"
                  SelectedItem="{Binding DeploymentType}"/>
        <Label Content="Deploy Mode" Grid.Column="2" Margin="12,0,0,0"/>
        <ComboBox Grid.Column="3" ItemsSource="{Binding DeployModes}"
                  SelectedItem="{Binding DeployMode}"
                  ToolTip="Silent is recommended: scripts run as SYSTEM in session 0, so Interactive UI will not be visible to logged-on users unless the package handles it (e.g. ServiceUI). Auto (PSADT v4 only) lets the toolkit pick Interactive when a user is logged on, Silent otherwise — v3 packages reject it."/>
        <Label Content="Timeout (min)" Grid.Column="4" Margin="12,0,0,0"/>
        <TextBox Grid.Column="5" Text="{Binding TimeoutMinutes}"/>
      </Grid>

      <Grid Margin="0,3">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="120"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Label Content="Extra Arguments"/>
        <TextBox Grid.Column="1" Text="{Binding AdditionalArguments}"
                 ToolTip="Appended to the PSADT entry point, e.g. -AllowRebootPassThru"/>
        <CheckBox Grid.Column="2" Content="Clean up temp files" Margin="12,0,0,0"
                  VerticalAlignment="Center" IsChecked="{Binding CleanupTemporaryFiles}"
                  ToolTip="Deletes the working folder (C:\AVSR\&lt;id&gt;: downloaded zip + extracted package) from the VM after the deployment finishes. Untick to keep it for troubleshooting — remember to remove it manually."/>
      </Grid>

      <Grid Margin="0,3">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="120"/>
          <ColumnDefinition Width="60"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Label Content="Parallelism"/>
        <TextBox Grid.Column="1" Text="{Binding MaxParallelism}"/>
        <TextBlock Grid.Column="2" FontSize="11" Foreground="{StaticResource Brush.TextMuted}"
                   VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"
                   Text="Deployments are staggered: this many VMs run at once (e.g. 30 VMs at 10 = three waves). Each VM still gets its own timeout and result."/>
      </Grid>
    </StackPanel>

    <!-- Actions -->
    <StackPanel Grid.Row="2" Margin="0,10,0,8">
      <StackPanel Orientation="Horizontal">
        <Button Content="🚀  Deploy to Selected VMs" Style="{StaticResource Button.Hero}"
                Command="{Binding DeployCommand}"/>
        <Button Content="Cancel" Style="{StaticResource Button.Tool}" Margin="8,0,0,0"
                Command="{Binding CancelCommand}"/>
        <Button Content="Save as Task" Style="{StaticResource Button.Tool}" Margin="8,0,0,0"
                Command="{Binding SaveAsTaskCommand}"
                ToolTip="Save this deployment as a reusable task on the Tasks page"/>
        <ProgressBar Width="140" Height="6" Margin="12,0,0,0" VerticalAlignment="Center"
                     IsIndeterminate="{Binding IsRunning}"
                     Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
      </StackPanel>
      <TextBlock FontSize="11" Foreground="{StaticResource Brush.TextMuted}" TextWrapping="Wrap" Margin="0,6,0,0"
                 Text="'Save as Task' makes this deployment reusable on the Tasks page and schedulable on the Schedule page. Scheduling a PSADT task needs ONE one-time setup for the whole environment: the scheduler's identity gets 'Storage Blob Data Reader' on the package storage account (attempted automatically when you create the schedule). Individual VMs need no identities or permissions. Full steps: Prep page."/>
    </StackPanel>

    <!-- Results + log -->
    <Grid Grid.Row="3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="380"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <DataGrid Grid.Column="0" ItemsSource="{Binding Rows}" IsReadOnly="True">
        <DataGrid.Columns>
          <DataGridTextColumn Header="VM" Binding="{Binding VmName}" Width="130"/>
          <DataGridTemplateColumn Header="Status" Width="130" SortMemberPath="Status">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Status}" VerticalAlignment="Center">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                          <Setter Property="Foreground" Value="{StaticResource Brush.StatusGreen}"/>
                          <Setter Property="FontWeight" Value="SemiBold"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsFailure}" Value="True">
                          <Setter Property="Foreground" Value="{StaticResource Brush.StatusRed}"/>
                          <Setter Property="FontWeight" Value="SemiBold"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="Exit" Binding="{Binding ExitCode}" Width="50"/>
          <DataGridTextColumn Header="Time" Binding="{Binding Duration}" Width="*"/>
        </DataGrid.Columns>
      </DataGrid>

      <Border Grid.Column="2" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="3">
        <TextBox x:Name="LogBox" Style="{StaticResource Input.Log}"
                 Text="{Binding LogText, Mode=OneWay}" TextChanged="LogBox_TextChanged"/>
      </Border>
    </Grid>
  </Grid>
</UserControl>
