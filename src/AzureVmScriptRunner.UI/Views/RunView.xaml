<UserControl x:Class="AzureVmScriptRunner.UI.Views.RunView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AzureVmScriptRunner.UI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:RunViewModel}">

  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
  </UserControl.Resources>

  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- Target safety panel -->
      <RowDefinition Height="Auto"/>  <!-- Options row -->
      <RowDefinition Height="170"/>   <!-- Script editor -->
      <RowDefinition Height="Auto"/>  <!-- Actions -->
      <RowDefinition Height="*"/>     <!-- Results + log -->
    </Grid.RowDefinitions>

    <!-- Target safety panel: always shows exactly which VMs will be hit -->
    <Border Grid.Row="0" Margin="0,0,0,8">
      <Border.Style>
        <Style TargetType="Border" BasedOn="{StaticResource Panel.Banner}">
          <Style.Triggers>
            <DataTrigger Binding="{Binding HasSelection}" Value="False">
              <Setter Property="Background" Value="#FFF8E1"/>
              <Setter Property="BorderBrush" Value="{StaticResource Brush.StatusAmber}"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <StackPanel>
        <TextBlock Text="{Binding TargetsText}" FontWeight="SemiBold"
                   Foreground="{StaticResource Brush.Brand}" FontSize="12"/>
        <ItemsControl ItemsSource="{Binding SelectedVmNames}" Margin="0,4,0,0">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Background="White" BorderBrush="{StaticResource Brush.Brand}"
                      BorderThickness="1" CornerRadius="9" Padding="8,2" Margin="0,2,6,2">
                <TextBlock Text="{Binding}" FontSize="11" Foreground="{StaticResource Brush.BrandDark}"/>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>

    <!-- Options -->
    <WrapPanel Grid.Row="1" Margin="0,0,0,8" VerticalAlignment="Center">
      <TextBlock Text="Shell:" VerticalAlignment="Center" FontSize="11"
                 Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,4,0"/>
      <ComboBox Width="110" ItemsSource="{Binding ShellTypes}" SelectedItem="{Binding ShellType}"/>

      <TextBlock Text="Timeout (min):" VerticalAlignment="Center" FontSize="11"
                 Foreground="{StaticResource Brush.TextMuted}" Margin="14,0,4,0"/>
      <TextBox Width="50" Text="{Binding TimeoutMinutes}"/>

      <TextBlock Text="Parallelism:" VerticalAlignment="Center" FontSize="11"
                 Foreground="{StaticResource Brush.TextMuted}" Margin="14,0,4,0"/>
      <TextBox Width="50" Text="{Binding MaxParallelism}"/>

      <TextBlock Text="{Binding LoadedTaskName}" VerticalAlignment="Center" FontSize="12"
                 FontWeight="SemiBold" Foreground="{StaticResource Brush.Brand}" Margin="16,0,0,0"/>
    </WrapPanel>

    <!-- Script editor -->
    <TextBox Grid.Row="2" Style="{StaticResource Input.Script}"
             Text="{Binding ScriptText, UpdateSourceTrigger=PropertyChanged}"
             ToolTip="The script or command to execute on every selected VM"/>

    <!-- Actions -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8">
      <Button Content="▶  Run on Selected VMs" Style="{StaticResource Button.Hero}"
              Command="{Binding RunCommand}"/>
      <Button Content="Cancel" Style="{StaticResource Button.Tool}" Margin="8,0,0,0"
              Command="{Binding CancelCommand}"/>
      <ProgressBar Width="140" Height="6" Margin="12,0,0,0" VerticalAlignment="Center"
                   IsIndeterminate="{Binding IsRunning}"
                   Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
    </StackPanel>

    <!-- Results + log -->
    <Grid Grid.Row="4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="380"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <DataGrid Grid.Column="0" ItemsSource="{Binding Rows}" IsReadOnly="True">
        <DataGrid.Columns>
          <DataGridTextColumn Header="VM" Binding="{Binding VmName}" Width="130"/>
          <DataGridTemplateColumn Header="Status" Width="130" SortMemberPath="Status">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Status}" VerticalAlignment="Center">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                          <Setter Property="Foreground" Value="{StaticResource Brush.StatusGreen}"/>
                          <Setter Property="FontWeight" Value="SemiBold"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsFailure}" Value="True">
                          <Setter Property="Foreground" Value="{StaticResource Brush.StatusRed}"/>
                          <Setter Property="FontWeight" Value="SemiBold"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="Exit" Binding="{Binding ExitCode}" Width="50"/>
          <DataGridTextColumn Header="Time" Binding="{Binding Duration}" Width="*"/>
        </DataGrid.Columns>
      </DataGrid>

      <!-- Activity log (suite convention) -->
      <Border Grid.Column="2" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="3">
        <TextBox x:Name="LogBox" Style="{StaticResource Input.Log}"
                 Text="{Binding LogText, Mode=OneWay}" TextChanged="LogBox_TextChanged"/>
      </Border>
    </Grid>
  </Grid>
</UserControl>
