<UserControl x:Class="AzureVmScriptRunner.UI.Views.FilterDropdown"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AzureVmScriptRunner.UI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MultiSelectFilter}">

  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
    <TextBlock Text="{Binding Header, StringFormat='{}{0}:'}" VerticalAlignment="Center" FontSize="11"
               Foreground="{StaticResource Brush.TextMuted}" Margin="0,0,4,0"/>
    <ToggleButton x:Name="DropButton" MinWidth="110" Padding="8,3" Cursor="Hand"
                  Background="White" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="{Binding Summary}" FontSize="12"/>
        <TextBlock Text=" ▾" FontSize="10" VerticalAlignment="Center"/>
      </StackPanel>
    </ToggleButton>
    <Popup IsOpen="{Binding IsChecked, ElementName=DropButton}" StaysOpen="False"
           PlacementTarget="{Binding ElementName=DropButton}" Placement="Bottom"
           Closed="Popup_Closed">
      <Border Background="White" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
              CornerRadius="3" Padding="8" MinWidth="180" MaxHeight="320">
        <DockPanel>
          <Button DockPanel.Dock="Bottom" Content="Clear (show all)" FontSize="11" Margin="0,6,0,0"
                  Style="{StaticResource Button.Tool}" Command="{Binding ClearCommand}"/>
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Options}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <CheckBox Content="{Binding Label}" IsChecked="{Binding IsChecked}" Margin="0,2" FontSize="12"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Popup>
  </StackPanel>
</UserControl>
