<Window x:Class="AzureVmScriptRunner.UI.Views.PromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Azure VM Script Runner"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

  <StackPanel>
    <Border Background="{StaticResource Brush.HeaderGradient}" Height="44">
      <TextBlock x:Name="HeaderText" Style="{StaticResource Text.HeaderTitle}" FontSize="16"
                 VerticalAlignment="Center" Margin="14,0"/>
    </Border>
    <StackPanel Margin="14,12">
      <TextBlock x:Name="PromptText" TextWrapping="Wrap" Margin="0,0,0,8"/>
      <TextBox x:Name="InputBox" Padding="5,4"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
        <Button Content="OK" Style="{StaticResource Button.Primary}" Width="86" Click="Ok_Click" IsDefault="True"/>
        <Button Content="Cancel" Style="{StaticResource Button.Tool}" Width="86" Margin="8,0,0,0"
                Click="Cancel_Click" IsCancel="True"/>
      </StackPanel>
    </StackPanel>
  </StackPanel>
</Window>
