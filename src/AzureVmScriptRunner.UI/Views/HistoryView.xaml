<UserControl x:Class="AzureVmScriptRunner.UI.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AzureVmScriptRunner.UI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:HistoryViewModel}">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Style="{StaticResource Panel.Toolbar}">
      <WrapPanel VerticalAlignment="Center">
        <Button Content="Refresh" Style="{StaticResource Button.Primary}" Command="{Binding RefreshCommand}"/>
        <TextBlock Text="Search:" VerticalAlignment="Center" FontSize="11"
                   Foreground="{StaticResource Brush.TextMuted}" Margin="10,0,4,0"/>
        <TextBox Width="240" VerticalAlignment="Center"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="Search name, VM or script content — press Refresh to apply"/>
        <TextBlock Text="Range:" VerticalAlignment="Center" FontSize="11"
                   Foreground="{StaticResource Brush.TextMuted}" Margin="12,0,4,0"/>
        <ComboBox Width="130" ItemsSource="{Binding RangeOptions}" SelectedItem="{Binding Range}"/>
        <TextBlock Text="{Binding SummaryText}" VerticalAlignment="Center" FontSize="12"
                   FontWeight="SemiBold" Foreground="{StaticResource Brush.Brand}" Margin="12,0,0,0"/>
      </WrapPanel>
    </Border>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" MinWidth="420"/>
        <ColumnDefinition Width="4"/>
        <ColumnDefinition Width="1.2*"/>
      </Grid.ColumnDefinitions>

      <DataGrid Grid.Column="0" ItemsSource="{Binding Records}" IsReadOnly="True"
                SelectedItem="{Binding SelectedRecord}" SelectionMode="Single">
        <DataGrid.Columns>
          <DataGridTextColumn Header="When" Binding="{Binding When}" Width="140"/>
          <DataGridTextColumn Header="VM" Binding="{Binding VmName}" Width="120"/>
          <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/>
          <DataGridTextColumn Header="Type" Binding="{Binding TypeText}" Width="100"/>
          <DataGridTemplateColumn Header="Status" Width="140" SortMemberPath="StatusText">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Foreground" Value="{StaticResource Brush.StatusRed}"/>
                      <Setter Property="FontWeight" Value="SemiBold"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                          <Setter Property="Foreground" Value="{StaticResource Brush.StatusGreen}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="Exit" Binding="{Binding ExitText}" Width="48"/>
          <DataGridTextColumn Header="Time" Binding="{Binding DurationText}" Width="60"/>
        </DataGrid.Columns>
      </DataGrid>

      <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                    Background="{StaticResource Brush.BorderLight}"/>

      <Border Grid.Column="2" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
              CornerRadius="3" Margin="6">
        <TextBox Style="{StaticResource Input.Log}"
                 Text="{Binding SelectedRecord.DetailText, Mode=OneWay, FallbackValue='Select a record to see the script, output and errors.'}"/>
      </Border>
    </Grid>

    <Border Grid.Row="2" Background="{StaticResource Brush.Footer}"
            BorderBrush="{StaticResource Brush.BorderLight}" BorderThickness="0,1,0,0" Padding="12,4">
      <TextBlock Style="{StaticResource Text.Footer}"
                 Text="Local history for this machine. The Azure Activity Log remains the authoritative audit trail."/>
    </Border>
  </Grid>
</UserControl>
