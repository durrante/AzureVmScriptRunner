<Window x:Class="AzureVmScriptRunner.UI.Views.TaskEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Saved Task"
        Width="680" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" MinWidth="560" MinHeight="460">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="52"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource Brush.HeaderGradient}">
      <TextBlock x:Name="HeaderText" Text="New Task" Style="{StaticResource Text.HeaderTitle}"
                 FontSize="18" VerticalAlignment="Center" Margin="16,0"/>
    </Border>

    <StackPanel Grid.Row="1" Margin="14,10,14,0">
      <Grid Margin="0,3">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="90"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="80"/>
          <ColumnDefinition Width="140"/>
        </Grid.ColumnDefinitions>
        <Label Content="Name *"/>
        <TextBox x:Name="TxtName" Grid.Column="1"/>
        <Label Content="Category" Grid.Column="2" Margin="10,0,0,0"/>
        <TextBox x:Name="TxtCategory" Grid.Column="3"/>
      </Grid>

      <Grid Margin="0,3">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="90"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Label Content="Description"/>
        <TextBox x:Name="TxtDescription" Grid.Column="1"/>
      </Grid>

      <Grid Margin="0,3">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="90"/>
          <ColumnDefinition Width="180"/>
        </Grid.ColumnDefinitions>
        <Label Content="Type"/>
        <ComboBox x:Name="CmbShell" Grid.Column="1" SelectionChanged="CmbShell_SelectionChanged">
          <ComboBoxItem Content="PowerShell" IsSelected="True"/>
          <ComboBoxItem Content="CMD"/>
          <ComboBoxItem Content="PSADT Deployment"/>
        </ComboBox>
      </Grid>
    </StackPanel>

    <!-- Script editor (PowerShell / CMD) -->
    <Grid Grid.Row="2" Margin="14,4,14,0">
      <DockPanel x:Name="PanelScript">
        <TextBlock DockPanel.Dock="Top" Text="Script / Command" Style="{StaticResource Text.SectionHeader}"/>
        <TextBox x:Name="TxtScript" Style="{StaticResource Input.Script}" Margin="0,4,0,0"/>
      </DockPanel>

      <!-- PSADT form -->
      <StackPanel x:Name="PanelPsadt" Visibility="Collapsed">
        <TextBlock Text="PSADT Package" Style="{StaticResource Text.SectionHeader}"/>
        <Grid Margin="0,3">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Label Content="Package URL *"/>
          <TextBox x:Name="TxtPackageUrl" Grid.Column="1"
                   ToolTip="Full https:// URL to the .zip PSADT package — no SAS token"/>
        </Grid>
        <Grid Margin="0,3">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="140"/>
          </Grid.ColumnDefinitions>
          <Label Content="Type"/>
          <ComboBox x:Name="CmbPsadtType" Grid.Column="1">
            <ComboBoxItem Content="Install" IsSelected="True"/>
            <ComboBoxItem Content="Uninstall"/>
            <ComboBoxItem Content="Repair"/>
          </ComboBox>
          <Label Content="Deploy Mode" Grid.Column="2" Margin="10,0,0,0"/>
          <ComboBox x:Name="CmbPsadtMode" Grid.Column="3"
                    ToolTip="Auto is PSADT v4 only. Silent is the safe default (SYSTEM/session 0).">
            <ComboBoxItem Content="Silent" IsSelected="True"/>
            <ComboBoxItem Content="Interactive"/>
            <ComboBoxItem Content="NonInteractive"/>
            <ComboBoxItem Content="Auto"/>
          </ComboBox>
        </Grid>
        <Grid Margin="0,3">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Label Content="Extra Arguments"/>
          <TextBox x:Name="TxtPsadtArgs" Grid.Column="1"/>
          <CheckBox x:Name="ChkCleanup" Grid.Column="2" Content="Clean up temp files"
                    IsChecked="True" Margin="10,0,0,0" VerticalAlignment="Center"/>
        </Grid>
        <Border Style="{StaticResource Panel.Banner}" Margin="0,8,0,0">
          <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource Brush.BrandDark}"
                     Text="Package access is automatic. Run Now: 1-hour SAS issued under your identity (VM identity used first if present). Scheduled: the scheduler's identity mints a fresh token at fire time — it needs 'Storage Blob Data Reader' on the package storage account, granted automatically at schedule creation if you have rights. VMs need no identities or permissions either way."/>
        </Border>
      </StackPanel>
    </Grid>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="14,10">
      <Button Content="Save" Style="{StaticResource Button.Primary}" Width="90" Click="Save_Click"/>
      <Button Content="Cancel" Style="{StaticResource Button.Tool}" Width="90" Margin="8,0,0,0" Click="Cancel_Click"/>
    </StackPanel>
  </Grid>
</Window>
